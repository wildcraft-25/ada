Discrete Knapsack (0/1 Kanpsack)
#include<stdio.h>
void main()
{
 float weight[10],profit[10],ratio[10],x[10],maxprofit,temp,capacity,amount;
 int n,i,j;
 printf("Enter the number of items :");
 scanf("%d",&n); 
 printf("Enter Weights \n");
 for (i = 0; i < n; i++)
 scanf("%f", &weight[i]);
 
 printf("Enter Profits \n");
 for (i = 0; i < n; i++)
 scanf("%f", &profit[i]);
 
 printf("Enter the capacity of knapsack :\n"); 
 scanf("%f",&capacity);
 
 for(i=0;i<n;i++)
 x[i]=0;
 for(i=0;i<n;i++)
 ratio[i]=profit[i]/weight[i];
 for (i = 0; i < n; i++) 
 for (j = i + 1; j < n; j++) 
 if (ratio[i] < ratio[j]) 
 {
 temp = ratio[j];
 ratio[j] = ratio[i];
 ratio[i] = temp;
 temp = weight[j];
 weight[j] = weight[i];
 weight[i] = temp;
 temp = profit[j];
 profit[j] = profit[i];
 profit[i] = temp;
 }
 for (i = 0; i < n; i++) 
 {
 if (weight[i] > capacity)
 x[i]=0;
 else 
 {
 x[i]=1;
 maxprofit = maxprofit + profit[i];
 capacity = capacity - weight[i];
 }
 } 
 
 
 printf("\n Solution vector\n");
 for(i=0;i<n;i++)
 printf("%f\t ",x[i]);
 printf("\nThe maximum value is :%f\n",maxprofit); 
}



