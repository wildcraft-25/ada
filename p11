void mergeSort(int a[], int n) 
{
 int mid,i,b[10000],c[10000];
 if (n >1)
 { 
 mid = n / 2;
 for (i = 0; i < mid; i++)
 b[i] = a[i];
 for (i =mid ; i < n; i++)
 c[i-mid] = a[i];
