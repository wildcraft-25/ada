#include <stdio.h>
void main()
{
 int i,j,ne,n,source,target ,min, mincost=0;
 int cost[10][10], visited[10];
 printf("Enter Number of Vertices: ");
 scanf("%d", &n);
 
 printf("Enter Cost Adjacency Matrix:\n");
 for (int i = 0; i < n; i++) 
 {
 for (int j = 0; j < n; j++) 
 scanf("%d", &cost[i][j]);
 }
 for (int i = 0; i < n; i++)
 visited[i] = 0;
 
 printf("Enter Source Vertex: ");
 scanf("%d", &source);
 
 visited[source] = 1;
 ne=1;
 while(ne<n)
 {
 min = 999;
 for (i=0;i<n;i++) 
 {
 if (visited[i]) 
 {
 for (j = 0; j< n; j++) 
 { 
 if (cost[i][j]<min && !visited[j])
 {
 min = cost[i][j]; 
 source=i;
 target =j;
 }
 }
 }
 }
 visited[target] = 1;
 printf(" \n Edge %d (%d->%d) %d ", ne++, source , target, min);
 mincost=mincost+min;
 }
 printf("\nMinimum cost of Spanning Tree: %d\n", mincost);
} 
