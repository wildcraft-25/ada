#include <stdio.h>
int parent[10];
int find(int i) 
{
 while (parent[i] != i)
 i = parent[i];
 return i;
}
void union1(int u, int v) 
{
 int a =find(u);
 int b= find(v);
 parent[a]=b;
} 
void main() 
{
 int i,j,ne,n,source,target ,min, mincost;
 int cost [10][10];
 
 printf("Enter the number of vertices of the graph\n");
 scanf("%d", &n);
 
 for (i = 0; i < n; i++)
 parent[i] = i;
 printf("Enter the weighted matrix\n");
 for (i = 0; i < n; i++)
 for (j = 0; j < n; j++)
 scanf("%d", &cost[i][j]);
 ne=1;
 mincost=0;
 
 while ( ne < n) 
 {
 min = 999;
 for (i = 0; i < n; i++) 
 {
 for (j = 0; j <n; j++)
 {
 if ((cost[i][j] < min) && (find(i)!=find(j)))
 {
 min = cost[i][j];
 source = i;
 target = j;
 } 
 }
 }
 
 union1(source,target);
 printf(" \n Edge %d (%d->%d) %d ", ne++, source,target ,min);
 mincost=mincost+min;
 }
 printf("\nMinimum cost of Spanning Tree: %d\n", mincost);
}
 
